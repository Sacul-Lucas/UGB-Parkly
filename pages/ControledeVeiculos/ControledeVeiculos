<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="img/favicon.png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="ControleVeiculos.css">
    <title>UGB Parkly</title>
</head>
<body>
   <!-- SIDEBAR -->
<aside class="sidebar">
   <div class="sidebar-logo">
     <img src="img/logo1.png">
   </div>
  <br>
  <div class="sidebar-icon" title="Dashboard">
    <i class="fa-solid fa-chart-line"></i>
  </div>
  <br>
  <div class="sidebar-icon " title="Veículos">
    <i class="fa-solid fa-car"></i>
  </div>
  <br>
  <div class="sidebar-icon" title="Registros">
   <i class="fa-regular fa-file"></i>
  </div>
  <br>
  <div class="sidebar-icon active" title="Controle de Vagas">
    <i class="fa-solid fa-square-parking"></i>
  </div>
  <br>
  <div class="sidebar-icon" title="Usuários">
    <i class="fa-solid fa-users"></i>
  </div>
  <br>
  <div class="sidebar-icon" title="Configurações">
    <i class="fa-solid fa-gear"></i>
  </div>
  
</aside>
 
<main class="main">
 
  <!-- HEADER -->
  <div class="header">
    <div class="header-left">
      <h1>Controle de Veículos</h1>
      <p>Gerencie todos os veículos e seus proprietários</p>
    </div>
    <div class="header-right">
      <button class="btn btn-outline">📥 Exportar</button>
      <button class="btn btn-primary" onclick="openModal()">＋ Novo Veículo</button>
    </div>
  </div>
 
  <!-- STATS -->
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-label">Total de Veículos</div>
      <div class="stat-value">48</div>
      <div class="stat-sub">Cadastrados</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Estacionados Agora</div>
      <div class="stat-value">13 <span>/ 50</span></div>
      <div class="stat-sub"><span class="stat-dot" style="background:var(--green)"></span>26% ocupação</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Disponíveis</div>
      <div class="stat-value" style="color:var(--green)">35</div>
      <div class="stat-sub">vagas livres</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Pendências</div>
      <div class="stat-value" style="color:var(--yellow)">5</div>
      <div class="stat-sub">documentos a atualizar</div>
    </div>
  </div>
 
  <!-- TOOLBAR -->
  <div class="toolbar">
    <div class="search-wrap">
      <span class="search-icon">🔍</span>
      <input class="search-input" type="text" placeholder="Buscar por placa, modelo ou proprietário..." oninput="filterTable(this.value)">
    </div>
    <select class="filter-select" onchange="filterStatus(this.value)">
      <option value="">Todos os status</option>
      <option value="Estacionado">Estacionado</option>
      <option value="Disponível">Disponível</option>
    </select>
    <select class="filter-select">
      <option>Todos os tipos</option>
      <option>Carro</option>
      <option>Moto</option>
      <option>SUV</option>
    </select>
  </div>
 
  <!-- TABLE -->
  <div class="table-card">
    <div class="table-header">
      <h2>Veículos Cadastrados</h2>
      <span class="table-count" id="count-label">8 veículos</span>
    </div>
    <table>
      <thead>
        <tr>
          <th>Placa</th>
          <th>Proprietário</th>
          <th>Veículo</th>
          <th>Tipo</th>
          <th>Status</th>
          <th>Última Entrada</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody id="table-body">
      </tbody>
    </table>
    <div class="pagination">
      <span>Mostrando <strong>1–8</strong> de <strong>48</strong> veículos</span>
      <div class="page-btns">
        <button class="page-btn">‹</button>
        <button class="page-btn active">1</button>
        <button class="page-btn">2</button>
        <button class="page-btn">3</button>
        <button class="page-btn">›</button>
      </div>
    </div>
  </div>
 
</main>
 
<!-- MODAL NOVO VEÍCULO -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <div class="modal-title">
      <span>Cadastrar Veículo</span>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="form-grid">
      <div class="form-group">
        <label>Placa</label>
        <input type="text" placeholder="ABC-1234" maxlength="8">
      </div>
      <div class="form-group">
        <label>Ano</label>
        <input type="number" placeholder="2023" min="1990" max="2026">
      </div>
      <div class="form-group">
        <label>Modelo</label>
        <input type="text" placeholder="Ex: Civic">
      </div>
      <div class="form-group">
        <label>Marca</label>
        <input type="text" placeholder="Ex: Honda">
      </div>
      <div class="form-group">
        <label>Tipo</label>
        <select>
          <option>Carro</option>
          <option>SUV</option>
          <option>Moto</option>
          <option>Caminhonete</option>
        </select>
      </div>
      <div class="form-group">
        <label>Cor</label>
        <input type="text" placeholder="Ex: Prata">
      </div>
      <div class="form-group form-full">
        <label>Proprietário</label>
        <input type="text" placeholder="Nome completo">
      </div>
      <div class="form-group form-full">
        <label>Contato</label>
        <input type="text" placeholder="(24) 99999-0000">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal()">Cancelar</button>
      <button class="btn btn-primary" onclick="closeModal()">Salvar Veículo</button>
    </div>
  </div>
</div>

<script src="script.js"></script>

</body>
</html>
